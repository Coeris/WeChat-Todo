<view class="tab-bar {{darkMode ? 'dark' : ''}}">
  <view
    class="tab-bar-item"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab">
    <image class="tab-bar-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" />
  </view>
</view>
