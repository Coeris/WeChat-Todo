.container {
  min-height: 100vh;
  background: #ededed;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.container.dark {
  background: #191919;
}

.section {
  margin: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dark .card {
  background: #1e293b;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  background: #e0f2fe;
}

.dark .card-icon {
  background: rgba(56, 189, 248, 0.15);
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.card-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.dark .card-name {
  color: #fff;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}

.dark .card-desc {
  color: rgba(255, 255, 255, 0.5);
}

.card-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin-left: 116rpx;
}

.dark .card-divider {
  background: rgba(255, 255, 255, 0.1);
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  color: #333;
  font-size: 28rpx;
  flex-shrink: 0;
}

.dark .picker-value {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.picker-arrow {
  font-size: 26rpx;
  color: #999;
  line-height: 1;
  transform: rotate(-90deg);
}

/* 开关 */
.switch {
  width: 100rpx;
  height: 56rpx;
  background: #d9d9d9;
  border-radius: 28rpx;
  position: relative;
  transition: all 0.3s;
  flex-shrink: 0;
}

.switch.on {
  background: #07c160;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.switch.on .switch-knob {
  left: 48rpx;
}

/* 行内提示 */
.card-tip {
  padding: 8rpx 24rpx 16rpx 116rpx;
  font-size: 24rpx;
  color: #f0a020;
  line-height: 1.5;
}

.dark .card-tip {
  color: rgba(240, 160, 32, 0.7);
}

/* 分割线 */

.tip-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.dark .tip-text {
  color: rgba(255, 255, 255, 0.4);
}
