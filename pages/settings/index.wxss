.container {
  min-height: 100vh;
  background: #ededed;
  padding-bottom: calc(50px + env(safe-area-inset-bottom) + 40rpx);
}

.container.dark {
  background: #191919;
}

/* 用户卡片 */
.user-card {
  background: #07c160;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
}

.avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.welcome {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-value.completed {
  color: #a7f3d0;
}

.stat-value.pending {
  color: #fde68a;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 进度卡片 */
.progress-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dark .progress-card {
  background: #1e293b;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.dark .progress-title {
  color: #fff;
}

.progress-percent {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
  line-height: 1;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-text {
  font-size: 24rpx;
  color: #666;
}

.dark .info-text {
  color: rgba(255, 255, 255, 0.6);
}

.info-hint {
  font-size: 22rpx;
  color: #999;
}

.dark .info-hint {
  color: rgba(255, 255, 255, 0.4);
}

/* 菜单区域 */
.menu-section,
.settings-section,
.other-section {
  margin: 0 24rpx 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  position: relative;
}

.dark .section-title {
  color: #fff;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: #07c160;
  border-radius: 3rpx;
}

.menu-list,
.other-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dark .menu-list,
.dark .other-list {
  background: #1e293b;
}

.menu-item,
.other-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.dark .menu-item,
.dark .other-item {
  border-bottom-color: rgba(255, 255, 255, 0.1);
}

.menu-item:last-child,
.other-item:last-child {
  border-bottom: none;
}

.menu-item:active,
.other-item:active {
  background: #f8f9fa;
}

.dark .menu-item:active,
.dark .other-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-icon,
.other-icon {
  width: 72rpx;
  height: 72rpx;
  background: #07c160;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.other-icon {
  background: #07c160;
}

.menu-content,
.other-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title,
.other-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.dark .menu-title,
.dark .other-title {
  color: #fff;
}

.menu-subtitle,
.other-subtitle {
  font-size: 24rpx;
  color: #999;
}

.dark .menu-subtitle,
.dark .other-subtitle {
  color: rgba(255, 255, 255, 0.5);
}

.menu-arrow,
.other-arrow {
  font-size: 28rpx;
  color: #d9d9d9;
  font-weight: 300;
  flex-shrink: 0;
  transform: rotate(-90deg);
}

/* 设置卡片 */
.setting-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dark .setting-card {
  background: #1e293b;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.dark .setting-name {
  color: #fff;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.dark .setting-desc {
  color: rgba(255, 255, 255, 0.5);
}

.setting-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin-left: 116rpx;
}

.dark .setting-divider {
  background: rgba(255, 255, 255, 0.1);
}

/* 开关 */
.switch {
  width: 100rpx;
  height: 56rpx;
  background: #d9d9d9;
  border-radius: 28rpx;
  position: relative;
  transition: all 0.3s;
  flex-shrink: 0;
}

.switch.on {
  background: #07c160;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.switch.on .switch-knob {
  left: 48rpx;
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  color: #333;
  font-size: 28rpx;
}

.dark .picker-value {
  background: rgba(255, 255, 255, 0.1);
  color: #333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  line-height: 1;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 24rpx;
}

.version-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.dark .version-text {
  color: rgba(255, 255, 255, 0.4);
}

.copyright {
  font-size: 22rpx;
  color: #ccc;
}

.dark .copyright {
  color: rgba(255, 255, 255, 0.3);
}

/* 危险操作样式 */
.danger-text {
  color: #ff4d4f !important;
}

.danger-row:active {
  background: #fff1f0 !important;
}

/* 设置行带箭头点击样式 */
.setting-row {
  cursor: pointer;
}

.setting-arrow {
  font-size: 26rpx;
  color: #c0c0c0;
  font-weight: 300;
  flex-shrink: 0;
  transform: rotate(-90deg);
}

.map-key-input {
  width: 100%;
  height: 72rpx;
  background: var(--bg-input);
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: var(--text-main);
  box-sizing: border-box;
}
