/* pages/calculator/index.wxss */

/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  background: #ededed;
}

.container.dark {
  background: #111111;
}

/* ========== 页面滚动区 ========== */
.modules-wrap {
  padding: 24rpx;
  padding-bottom: calc(50px + env(safe-area-inset-bottom) + 24rpx);
}

/* ========== 模块区块 ========== */
.module-section {
  flex-shrink: 0;
}

.module-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.module-header-icon {
  font-size: 36rpx;
}

.module-header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .module-header-title {
  color: #e0e0e0;
}

.stock-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  padding-top: 12rpx;
  text-align: right;
}

.container.dark .stock-hint {
  color: rgba(255, 255, 255, 0.3);
}

.module-header-arrow {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
  transition: transform 0.25s ease;
}

.module-header-arrow.collapsed {
  transform: rotate(-90deg);
}

.container.dark .module-header-arrow {
  color: rgba(255, 255, 255, 0.3);
}

/* 统计数量标签 */
.stat-count {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #07C160;
  font-weight: 600;
  background: rgba(7, 193, 96, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.container.dark .stat-count {
  background: rgba(7, 193, 96, 0.15);
}

/* ========== 通用卡片 ========== */
.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.container.dark .card {
  background: #1e1e1e;
}

.input-card {
  padding: 32rpx;
}

/* ========== 区块标题 ========== */
.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #07C160;
  line-height: 1.2;
}

.container.dark .section-label {
  color: #e0e0e0;
}

/* ========== 统计计算器 - 输入区 ========== */
.input-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.input-item {
  flex: 1;
  min-width: 180rpx;
}

.input-chip {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 4rpx 0;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.container.dark .input-chip {
  background: rgba(255, 255, 255, 0.06);
}

.input-chip:focus-within {
  background: #fff;
  border-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.container.dark .input-chip:focus-within {
  background: rgba(255, 255, 255, 0.1);
  border-color: #07C160;
}

.chip-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  padding: 8rpx 24rpx 0;
}

.container.dark .chip-label {
  color: rgba(255, 255, 255, 0.4);
}

.chip-input {
  height: 80rpx;
  padding: 0 48rpx 0 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.container.dark .chip-input {
  color: #fff;
}

/* 输入框内包裹层 */
.chip-input-wrap {
  position: relative;
  width: 100%;
}

/* 输入框删除按钮 */
.chip-del-btn {
  position: absolute;
  right: 4rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #bbb;
  border-radius: 50%;
  z-index: 1;
  line-height: 1;
}

.chip-del-btn:active {
  color: #FA5151;
  background: rgba(250, 81, 81, 0.08);
}

.container.dark .chip-del-btn {
  color: rgba(255, 255, 255, 0.3);
}

.container.dark .chip-del-btn:active {
  color: #FA5151;
  background: rgba(250, 81, 81, 0.12);
}

/* 排序预览 */
.sorted-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(7, 193, 96, 0.04);
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.container.dark .sorted-preview {
  background: rgba(255, 255, 255, 0.03);
}

.sorted-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.container.dark .sorted-label {
  color: rgba(255, 255, 255, 0.4);
}

.sorted-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  word-break: break-all;
  flex: 1;
}

.container.dark .sorted-value {
  color: rgba(255, 255, 255, 0.6);
}

.sorted-copy-hint {
  font-size: 20rpx;
  color: #bbb;
  flex-shrink: 0;
}

.container.dark .sorted-copy-hint {
  color: rgba(255, 255, 255, 0.25);
}

/* 添加按钮（独立行） */
.add-btn-row {
  margin-bottom: 32rpx;
}

.add-chip-full {
  height: 72rpx;
  background: rgba(7, 193, 96, 0.08);
  border: 2rpx dashed #07C160;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon-full {
  font-size: 32rpx;
  color: #07C160;
  font-weight: 400;
  line-height: 1;
}

.add-text-full {
  font-size: 24rpx;
  color: #07C160;
}

.container.dark .add-chip-full {
  background: rgba(7, 193, 96, 0.1);
  border-color: #07C160;
}

/* 操作按钮行（添加 + 清空） */
.stat-action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.stat-action-btn.add {
  background: rgba(7, 193, 96, 0.08);
  border: 2rpx dashed #07C160;
  color: #07C160;
}

.stat-action-btn.add:active {
  background: rgba(7, 193, 96, 0.15);
}

.stat-action-btn.clear {
  background: rgba(250, 81, 81, 0.06);
  border: 2rpx dashed #FA5151;
  color: #FA5151;
}

.stat-action-btn.clear:active {
  background: rgba(250, 81, 81, 0.12);
}

.stat-action-icon {
  font-size: 28rpx;
  line-height: 1;
}

.container.dark .stat-action-btn.add {
  background: rgba(7, 193, 96, 0.1);
}

.container.dark .stat-action-btn.clear {
  background: rgba(250, 81, 81, 0.1);
}

/* 添加按钮（行内，已废弃保留） */
.input-add {
  max-width: 200rpx;
}

.add-chip {
  height: 80rpx;
  background: rgba(7, 193, 96, 0.08);
  border: 2rpx dashed #07C160;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 36rpx;
  color: #07C160;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #07C160;
}

/* ========== 统计结果网格 ========== */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.stat-item {
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: transform 0.15s ease;
}

.stat-item:active {
  transform: scale(0.97);
}

.container.dark .stat-item {
  background: rgba(255, 255, 255, 0.04);
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.container.dark .stat-label {
  color: rgba(255, 255, 255, 0.4);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  word-break: break-all;
}

.container.dark .stat-value {
  color: #e0e0e0;
}

/* ========== 详情卡片（关系/比例/股市） ========== */
.detail-card {
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 8rpx 0;
  margin-bottom: 36rpx;
}

.container.dark .detail-card {
  background: rgba(255, 255, 255, 0.04);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
}

.detail-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.container.dark .detail-row:not(:last-child) {
  border-bottom-color: rgba(255, 255, 255, 0.06);
}

.detail-row.highlight-row {
  background: rgba(7, 193, 96, 0.06);
  border-radius: 12rpx;
  margin: 4rpx 12rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.container.dark .detail-label {
  color: rgba(255, 255, 255, 0.6);
}

.detail-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .detail-value {
  color: #e0e0e0;
}

.detail-value.text-sm {
  font-size: 22rpx;
  text-align: right;
  max-width: 60%;
  line-height: 1.5;
}

/* 比例条 */
.ratio-bar-wrap {
  padding: 8rpx 24rpx 16rpx;
}

.ratio-bar {
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.container.dark .ratio-bar {
  background: rgba(255, 255, 255, 0.1);
}

.ratio-segment {
  height: 100%;
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.ratio-segment:first-child { border-radius: 8rpx 0 0 8rpx; }
.ratio-segment:last-child { border-radius: 0 8rpx 8rpx 0; }

.ratio-text {
  font-size: 22rpx;
  color: #999;
}

.container.dark .ratio-text {
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 清空按钮 ========== */
.clear-btn-wrap {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.wx-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}

.wx-btn-plain {
  background: transparent;
  color: #999;
  border: 2rpx solid #e0e0e0;
}

.wx-btn-plain:active {
  background: #f5f5f5;
  transform: scale(0.97);
}

.container.dark .wx-btn-plain {
  color: rgba(255, 255, 255, 0.5);
  border-color: rgba(255, 255, 255, 0.1);
}

.container.dark .wx-btn-plain:active {
  background: rgba(255, 255, 255, 0.06);
}

/* ========== 基础计算器 ========== */
.calc-display {
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  min-height: 110rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-end;
}

.container.dark .calc-display {
  background: rgba(255, 255, 255, 0.04);
}

.calc-expression {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
  word-break: break-all;
}

.container.dark .calc-expression {
  color: rgba(255, 255, 255, 0.4);
}

.calc-result {
  font-size: 56rpx;
  font-weight: 300;
  color: #333;
  word-break: break-all;
  line-height: 1.1;
}

.container.dark .calc-result {
  color: #fff;
}

/* 按键区 */
.calc-keypad {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.calc-key {
  aspect-ratio: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 400;
  color: #333;
  transition: all 0.12s ease;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.container.dark .calc-key {
  background: #2a2a2a;
  color: #e0e0e0;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

.calc-key:active {
  transform: scale(0.9);
  background: #e8e8e8;
}

.container.dark .calc-key:active {
  background: #333;
}

.calc-key.zero {
  aspect-ratio: auto;
}

/* 功能键 */
.calc-key.func {
  background: #e8e8e8;
  color: #333;
  font-size: 26rpx;
}

.container.dark .calc-key.func {
  background: #333;
  color: #bbb;
}

.calc-key.func:active {
  background: #d5d5d5;
}

.container.dark .calc-key.func:active {
  background: #3d3d3d;
}

.key-del-icon {
  font-size: 36rpx;
}

/* 运算符 */
.calc-key.op {
  background: #07C160;
  color: #fff;
  font-weight: 600;
  font-size: 34rpx;
}

.calc-key.op:active {
  background: #06AD56;
}

/* 等号 */
.calc-key.equal {
  background: #576B95;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.calc-key.equal:active {
  background: #4A5D7E;
}

/* ========== 百分比/股市 - 表单区域 ========== */
.field-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.field-label {
  min-width: 120rpx;
  max-width: 170rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  flex-shrink: 0;
  white-space: nowrap;
}

.container.dark .field-label {
  color: #e0e0e0;
}

.field-label.stock-label {
  min-width: 160rpx;
}

.field-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  position: relative;
}

.field-input {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  box-sizing: border-box;
}

.container.dark .field-input {
  background: rgba(255, 255, 255, 0.06);
  color: #fff;
}

.field-input:focus {
  background: #fff;
  border-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.08);
}

/* 带清除按钮的输入框需要额外右内边距 */
.field-input.has-clear {
  padding-right: 52rpx;
}

.container.dark .field-input:focus {
  background: rgba(255, 255, 255, 0.1);
  border-color: #07C160;
}

.field-suffix {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.container.dark .field-suffix {
  color: rgba(255, 255, 255, 0.4);
}

/* 结果输入框颜色（用于 field-input） */
.field-input.c-red-input {
  color: #FA5151;
}

.field-input.c-green-input {
  color: #07C160;
}

.container.dark .field-input.c-red-input {
  color: #FA5151;
}

.container.dark .field-input.c-green-input {
  color: #07C160;
}

/* 单位选择器组 */
.unit-toggle-group {
  display: flex;
  flex-wrap: wrap;
  flex-shrink: 0;
  margin-left: 12rpx;
  gap: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.unit-quick-btn {
  height: 88rpx;
  min-width: 88rpx;
  padding: 0 16rpx;
  background: #e8e8e8;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  border-radius: 0;
  border-right: 2rpx solid #d8d8d8;
  transition: all 0.2s ease;
}

.unit-quick-btn:last-child {
  border-right: none;
}

.unit-quick-btn.active {
  background: #07C160;
  color: #fff;
  border-right-color: rgba(7, 193, 96, 0.3);
}

.unit-quick-btn:active {
  opacity: 0.8;
}

.unit-picker-btn {
  height: 88rpx;
  min-width: 88rpx;
  padding: 0 20rpx;
  background: #e8e8e8;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s ease;
}

.unit-picker-btn:active {
  opacity: 0.8;
}

.unit-picker-btn.active {
  background: #07C160;
  color: #fff;
}

.unit-picker-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unit-picker-btn.active .unit-picker-text {
  color: #fff;
}

.unit-picker-arrow {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.unit-picker-btn.active .unit-picker-arrow {
  color: #fff;
}

.container.dark .unit-quick-btn {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.5);
}

.container.dark .unit-quick-btn.active {
  background: #07C160;
  color: #fff;
}

.container.dark .unit-picker-btn {
  background: rgba(255, 255, 255, 0.08);
}

.container.dark .unit-picker-text {
  color: rgba(255, 255, 255, 0.5);
}

.container.dark .unit-picker-arrow {
  color: rgba(255, 255, 255, 0.3);
}

.container.dark .unit-picker-btn.active {
  background: #07C160;
}

.container.dark .unit-picker-btn.active .unit-picker-text {
  color: #fff;
}

.container.dark .unit-picker-btn.active .unit-picker-arrow {
  color: #fff;
}

/* ========== 数量单位分组选择弹窗 ========== */
.unit-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: mask-fade-in 0.2s ease;
}

.unit-picker-mask-area {
  flex: 1;
}

@keyframes mask-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.unit-picker-popup {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  margin-bottom: env(safe-area-inset-bottom);
  animation: popup-slide-up 0.25s ease;
}

@keyframes popup-slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.container.dark .unit-picker-popup {
  background: #1e1e1e;
}

.unit-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.container.dark .unit-picker-header {
  border-bottom-color: rgba(255, 255, 255, 0.08);
}

.unit-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .unit-picker-title {
  color: #e0e0e0;
}

.unit-picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
  line-height: 1;
}

.container.dark .unit-picker-close {
  color: rgba(255, 255, 255, 0.5);
}

.unit-picker-body {
  flex: 1;
  height: 0;
  min-height: 0;
}

.unit-picker-scroll-inner {
  padding: 16rpx 0 calc(env(safe-area-inset-bottom) + 80rpx);
}

.unit-picker-bottom-line {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 40rpx auto 16rpx;
  width: 120rpx;
}

.container.dark .unit-picker-bottom-line {
  background: rgba(255, 255, 255, 0.08);
}

.unit-picker-group {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.unit-picker-group-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  padding: 12rpx 0;
  letter-spacing: 2rpx;
}

.container.dark .unit-picker-group-label {
  color: rgba(255, 255, 255, 0.35);
}

.unit-picker-group-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.unit-picker-item {
  min-width: 140rpx;
  height: 72rpx;
  padding: 0 28rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
  border: 2rpx solid transparent;
}

.unit-picker-item:active {
  opacity: 0.8;
}

.unit-picker-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
  border-color: #07C160;
}

.container.dark .unit-picker-item {
  background: rgba(255, 255, 255, 0.06);
  color: #e0e0e0;
}

.container.dark .unit-picker-item.active {
  background: #07C160;
  color: #fff;
}

/* 结果卡片 */
.result-card {
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 8rpx 0;
}

.container.dark .result-card {
  background: rgba(255, 255, 255, 0.04);
}

.result-card .section-label {
  padding-left: 20rpx;
  margin-bottom: 12rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
}

.result-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.container.dark .result-row:not(:last-child) {
  border-bottom-color: rgba(255, 255, 255, 0.06);
}

.result-row.highlight-row {
  background: rgba(7, 193, 96, 0.06);
  border-radius: 12rpx;
  margin: 4rpx 12rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.container.dark .result-label {
  color: rgba(255, 255, 255, 0.6);
}

.result-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .result-val {
  color: #e0e0e0;
}

/* ========== 颜色辅助类 ========== */
.c-green { color: #07C160 !important; }
.c-red { color: #FA5151 !important; }

/* ========== 单价换算 ========== */
.price-result-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.price-card {
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 16rpx 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: transform 0.15s ease;
  position: relative;
}

.price-card:active {
  transform: scale(0.97);
}

.container.dark .price-card {
  background: rgba(255, 255, 255, 0.04);
}

.price-card-tag {
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  font-size: 16rpx;
  color: #bbb;
  line-height: 1;
  z-index: 2;
}

.container.dark .price-card-tag {
  color: rgba(255, 255, 255, 0.25);
}

.price-card-label {
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
}

.container.dark .price-card-label {
  color: #e0e0e0;
}

.price-card-sub {
  font-size: 18rpx;
  font-weight: 400;
  color: #999;
  margin-left: 6rpx;
}

.container.dark .price-card-sub {
  color: rgba(255, 255, 255, 0.35);
}

.price-card-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 44rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  border-bottom: none;
}

.price-card-input::after {
  display: none;
}

.container.dark .price-card-input {
  color: #e0e0e0;
  background: rgba(255, 255, 255, 0.08);
}

.price-card-input:focus {
  border-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.price-card-input-placeholder {
  color: #ccc;
  font-weight: 400;
}

.container.dark .price-card-input-placeholder {
  color: rgba(255, 255, 255, 0.25);
}

.container.dark .price-card-input:focus {
  border-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.15);
}

/* 输入框删除按钮（数量/总价） */
.field-input-inner {
  flex: 1;
  position: relative;
}

.input-clear-btn {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #bbb;
  z-index: 1;
  line-height: 1;
  padding: 4rpx;
}

.input-clear-btn:active {
  color: #999;
}

.container.dark .input-clear-btn {
  color: rgba(255, 255, 255, 0.3);
}

/* 价格卡片输入框容器 */
.price-card-input-wrap {
  width: 100%;
  position: relative;
}

.price-card-clear {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #bbb;
  z-index: 1;
  line-height: 1;
  padding: 4rpx;
}

.price-card-clear:active {
  color: #999;
}

.container.dark .price-card-clear {
  color: rgba(255, 255, 255, 0.3);
}

/* ========== 清除按钮（内联） ========== */
.price-inline-btn {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ========== 单价换算 - 分类切换 ========== */
.price-category-wrap {
  margin-bottom: 24rpx;
}

.price-category-list {
  display: flex;
  gap: 16rpx;
}

.price-category-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.price-category-btn.active {
  background: #07c160;
  color: #fff;
  font-weight: 600;
}

.price-category-btn:active {
  opacity: 0.8;
}

.container.dark .price-category-btn {
  background: #2a2a2a;
  color: rgba(255, 255, 255, 0.5);
}

.container.dark .price-category-btn.active {
  background: #07c160;
  color: #fff;
}
