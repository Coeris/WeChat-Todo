.container {
  min-height: 100vh;
  background: #ededed;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.container.dark {
  background: #191919;
}

/* 区域 */
.section {
  margin: 24rpx;
}

/* 全局设置卡片 */
.global-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dark .global-card {
  background: #1e293b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.global-label-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.global-desc {
  font-size: 22rpx;
  color: #bbb;
}

.dark .global-desc {
  color: rgba(255, 255, 255, 0.35);
}

/* 模块项 - 独立卡片 */
.module-item {
  display: flex;
  flex-direction: column;
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 16rpx;
  transition: box-shadow 0.2s ease;
}

.module-item:last-child {
  margin-bottom: 0;
}

.dark .module-item {
  background: #1e293b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.module-item.disabled .module-name {
  color: #bbb;
}

.dark .module-item.disabled .module-name {
  color: rgba(255, 255, 255, 0.35);
}

/* 外层行 */
.module-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

/* 模块主体 */
.module-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  background: #e0f2fe;
}

.module-icon-wrap.dimmed {
  background: #f5f5f5;
}

.dark .module-icon-wrap {
  background: rgba(56, 189, 248, 0.15);
}

.dark .module-icon-wrap.dimmed {
  background: rgba(255, 255, 255, 0.06);
}

.module-icon {
  font-size: 36rpx;
}

.module-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  margin-left: 20rpx;
}

.module-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.dark .module-name {
  color: #fff;
}

.module-desc {
  font-size: 24rpx;
  color: #bbb;
}

.dark .module-desc {
  color: rgba(255, 255, 255, 0.35);
}

/* 展开箭头 */
.expand-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 28rpx;
  color: #ccc;
  transition: transform 0.25s ease;
  line-height: 1;
  transform: rotate(-90deg);
}

.arrow-icon.rotated {
  transform: rotate(0deg);
}

.dark .arrow-icon {
  color: rgba(255, 255, 255, 0.25);
}

/* ========== 展开面板 ========== */
.module-panel {
  padding: 0 24rpx 24rpx;
}

.panel-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
  margin-bottom: 8rpx;
}

.dark .panel-divider {
  background: rgba(255, 255, 255, 0.08);
}

.panel-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.panel-label {
  font-size: 28rpx;
  color: #555;
}

.dark .panel-label {
  color: rgba(255, 255, 255, 0.65);
}

.panel-sub-title {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.dark .panel-sub-title {
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 外层行内排序按钮 ========== */
.row-actions {
  display: flex;
  gap: 8rpx;
  margin-right: 4rpx;
}

.sort-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.sort-btn:active {
  background: #e4e4e4;
  transform: scale(0.9);
}

.sort-btn.disabled {
  opacity: 0.25;
  pointer-events: none;
}

.dark .sort-btn {
  background: rgba(255, 255, 255, 0.1);
}

.dark .sort-btn:active {
  background: rgba(255, 255, 255, 0.15);
}

.sort-btn-icon {
  font-size: 28rpx;
  color: #666;
  line-height: 1;
}

.dark .sort-btn-icon {
  color: rgba(255, 255, 255, 0.6);
}

/* ========== 开关 ========== */
.switch {
  width: 100rpx;
  height: 56rpx;
  background: #d9d9d9;
  border-radius: 28rpx;
  position: relative;
  transition: all 0.3s;
  flex-shrink: 0;
}

.switch.on {
  background: #07c160;
}

.dark .switch {
  background: rgba(255, 255, 255, 0.15);
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.switch.on .switch-knob {
  left: 48rpx;
}

/* ========== 涨跌颜色 ========== */
.color-mode-options {
  display: flex;
  gap: 20rpx;
}

.color-mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
  border-radius: 14rpx;
  background: #f7f7f7;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.color-mode-btn.active {
  border-color: #1296db;
  background: rgba(18, 150, 219, 0.06);
}

.dark .color-mode-btn {
  background: rgba(255, 255, 255, 0.06);
}

.dark .color-mode-btn.active {
  border-color: #1296db;
  background: rgba(18, 150, 219, 0.1);
}

.color-mode-btn:active {
  transform: scale(0.97);
}

.color-mode-preview {
  display: flex;
  gap: 16rpx;
  font-size: 28rpx;
}

.color-dot {
  font-size: 28rpx;
}

.c-red-dot {
  color: #FA5151;
}

.c-green-dot {
  color: #07C160;
}

.color-mode-name {
  font-size: 24rpx;
  color: #666;
}

.dark .color-mode-name {
  color: rgba(255, 255, 255, 0.6);
}

.color-mode-btn.active .color-mode-name {
  color: #1296db;
  font-weight: 500;
}

/* ========== 底部操作区 ========== */
.bottom-actions {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx 40rpx;
}

.reset-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 56rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.reset-btn:active {
  background: #f0f0f0;
  transform: scale(0.97);
}

.dark .reset-btn {
  background: #1e293b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.dark .reset-btn:active {
  background: #253347;
}

.reset-icon {
  font-size: 28rpx;
  color: #bbb;
}

.dark .reset-icon {
  color: rgba(255, 255, 255, 0.35);
}

.reset-text {
  font-size: 26rpx;
  color: #999;
}

.dark .reset-text {
  color: rgba(255, 255, 255, 0.5);
}
