/* 日历页面 - 仿滴答清单风格 */

.wx-calendar {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 50px - env(safe-area-inset-bottom));
  background: #ededed;
  position: relative;
  overflow: hidden;
}

/* ===== 顶部导航 ===== */
.wc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #ffffff;
  flex-shrink: 0;
}

.wc-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.wc-nav-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
}

.wc-nav-btn:active {
  background: #f0f0f0;
}

.wc-nav-icon {
  font-size: 48rpx;
  color: #333333;
  font-weight: 400;
  line-height: 1;
}

.wc-month-label {
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
}

.wc-year-input,
.wc-month-input {
  min-width: 48rpx;
  height: 52rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 600;
  color: #000000;
  border: 2rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 8rpx;
  background: #f9f9f9;
  box-sizing: border-box;
}

.wc-year-input {
  width: auto;
  max-width: 140rpx;
}

.wc-month-input {
  width: auto;
  max-width: 80rpx;
}

.wc-year-input:focus,
.wc-month-input:focus {
  border-color: #07c160;
  background: #ffffff;
}

.wc-separator {
  font-size: 38rpx;
  font-weight: 600;
  color: #000000;
  margin: 0 2rpx;
  letter-spacing: 1rpx;
}

.wc-today-btn {
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
  background: #07c160;
  position: relative;
}

.wc-today-btn:active {
  background: #06ad56;
}



.wc-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding: 12rpx 0 8rpx;
  background: #ffffff;
  flex-shrink: 0;
}

.wc-weekday {
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  font-weight: 400;
  line-height: 36rpx;
}

.wc-weekday-weekend {
  color: #e0564e;
}

/* ===== 固定周行（面板打开时顶部显示） ===== */
.wc-pinned-week {
  background: #ffffff;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
  border-bottom: 1rpx solid #ebebeb;
}

/* ===== 内联任务面板 ===== */
.wc-task-panel {
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  overflow: hidden;
  border-bottom: 1rpx solid #ebebeb;
  animation: wc-panel-in 0.18s ease-out;
}

@keyframes wc-panel-in {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 抽屉主体 */
.wc-sheet-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

/* 抽屉头部信息 */
.wc-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 14rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid #eeeeee;
  background: #ffffff;
}

.wc-sheet-date-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.wc-sheet-date-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  flex-shrink: 0;
}



.wc-sheet-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.wc-task-count {
  font-size: 22rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.wc-add-btn-sm {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.wc-add-btn-sm:active {
  background: #f0f0f0;
}

.wc-add-icon-sm {
  font-size: 36rpx;
  color: #07c160;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

/* 任务列表滚动区 */
.wc-sheet-task-scroll {
  flex: 1;
  min-height: 0;
}

.wc-sheet-task-inner {
  padding: 12rpx 32rpx 32rpx;
}

/* 任务项 */
.wc-task-item {
  width: 100%;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.wc-task-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.wc-task-item-inner {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  gap: 16rpx;
  flex: 1;
}

.wc-task-checkbox {
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
  background: #fff;
}

.wc-task-checkbox.completed {
  border-color: transparent;
  background: transparent;
}

.wc-check-icon {
  display: inline-block;
  opacity: 0;
  transform: scale(0);
}

.wc-task-checkbox.completed .wc-check-icon {
  font-size: 44rpx;
  color: #90ee90;
  opacity: 1;
  transform: scale(1);
}

.wc-task-checkbox.completed.animate-icon .wc-check-icon {
  animation: scaleIn 0.4s ease-out forwards !important;
}

@keyframes scaleIn {
  0% {
    opacity: 0;
    transform: scale(0);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.wc-task-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wc-task-title {
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 1.5;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.wc-title-done {
  color: #b0b0b0;
  text-decoration: line-through;
}

.wc-task-meta {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.wc-task-desc {
  font-size: 22rpx;
  color: #aaaaaa;
  overflow: hidden;
  white-space: nowrap;
}

/* 任务面板复选框优先级边框颜色 */
.wc-task-item.priority-0 .wc-task-checkbox { border-color: #d1d5db; }
.wc-task-item.priority-1 .wc-task-checkbox { border-color: #93c5fd; }
.wc-task-item.priority-2 .wc-task-checkbox { border-color: #fcd34d; }
.wc-task-item.priority-3 .wc-task-checkbox { border-color: #fca5a5; }

/* 任务面板完成状态优先级勾选颜色 */
.wc-task-item.priority-0 .wc-task-checkbox.completed .wc-check-icon { color: #b0b0b0; }
.wc-task-item.priority-1 .wc-task-checkbox.completed .wc-check-icon { color: #60a5fa; }
.wc-task-item.priority-2 .wc-task-checkbox.completed .wc-check-icon { color: #fbbf24; }
.wc-task-item.priority-3 .wc-task-checkbox.completed .wc-check-icon { color: #f87171; }

/* 已完成区域 */
.wc-completed-section {
  padding: 16rpx 8rpx 8rpx;
}

.wc-completed-title {
  font-size: 24rpx;
  color: #aaaaaa;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.wc-task-completed {
  opacity: 0.6;
}

/* 显示已完成按钮 */
.wc-show-completed {
  padding: 20rpx 0 8rpx;
  text-align: center;
}

.wc-show-completed-text {
  font-size: 24rpx;
  color: #576b95;
  padding: 8rpx 0;
}

/* 空状态 */
.wc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}

.wc-empty-icon {
  margin-bottom: 16rpx;
}

.wc-empty-icon-text {
  font-size: 64rpx;
  opacity: 0.5;
}

.wc-empty-text {
  font-size: 30rpx;
  color: #999999;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wc-empty-hint {
  font-size: 24rpx;
  color: #c0c0c0;
}

/* ===== 连续滚动区域 ===== */
.wc-scroll {
  flex: 1;
  min-height: 0;
  background: #ffffff;
  position: relative;
  transition: flex 0.15s ease, height 0.15s ease;
  contain: content;
}

/* 面板打开时折叠日历滚动区 */
.wc-scroll-collapsed {
  flex: 0 0 0px !important;
  height: 0 !important;
  min-height: 0 !important;
  overflow: hidden !important;
  padding: 0 !important;
  margin: 0 !important;
}

.wc-weeks-container {
  padding-bottom: 8rpx;
}

/* ===== 周块 ===== */
.wc-week-block {
  width: 100%;
  position: relative;
}

.wc-cal-week-row {
  display: flex;
  background: #ffffff;
  width: 100%;
  border-left: 1rpx solid #ebebeb;
  border-top: 1rpx solid #ebebeb;
  overflow: hidden;
  position: relative;
}

.wc-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 8rpx;
  position: relative;
  box-sizing: border-box;
  border-right: 1rpx solid #ebebeb;
  border-bottom: 1rpx solid #ebebeb;
  overflow: hidden;
}

/* 每行最后一个格子不加右边框 */
.wc-day:last-child {
  border-right: none;
}

.wc-day:active {
  background: rgba(0, 0, 0, 0.03);
}

.wc-day-month-label {
  font-size: 16rpx;
  color: #07c160;
  position: absolute;
  top: 2rpx;
  left: 6rpx;
  font-weight: 400;
}

.wc-day-num {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
  line-height: 40rpx;
  width: 44rpx;
  height: 44rpx;
  text-align: center;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 农历文字 */
.wc-day-lunar {
  font-size: 16rpx;
  color: #999999;
  line-height: 20rpx;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  flex-shrink: 0;
}

.wc-day-lunar-term {
  color: #07c160;
  font-weight: 500;
}

.wc-day-lunar-festival {
  color: #fa5151;
  font-weight: 500;
}

.wc-day-lunar-month {
  color: #333333;
  font-weight: 500;
}

/* 今天 — 绿色背景 + 白色文字（始终生效） */
.wc-day-today .wc-day-num {
  background: #07c160;
  color: #ffffff;
  font-weight: 500;
}

/* 非显示月份 */
.wc-day-other-month .wc-day-num {
  color: #c0c0c0;
}



/* 选中 — 默认（面板收起）不显示绿色 */
.wc-day-selected .wc-day-num {
  font-weight: 500;
}

.wc-day-today.wc-day-selected .wc-day-num {
  font-weight: 500;
}

/* 选中 — 面板展开时显示绿色 */
.wx-calendar.show-sheet .wc-day-selected .wc-day-num {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-weight: 500;
}

.wx-calendar.show-sheet .wc-day-today.wc-day-selected .wc-day-num {
  background: #07c160;
  color: #ffffff;
}

/* 有待办任务的日期 - 数字加粗 */
.wc-day-has-task .wc-day-num {
  font-weight: 600;
}

/* 周末日期 */
.wc-day-weekend .wc-day-num {
  color: #e0564e;
}

/* 今天且是周末 — 绿底白字优先 */
.wc-day-today.wc-day-weekend .wc-day-num {
  background: #07c160;
  color: #ffffff;
  font-weight: 500;
}

/* 任务标题文字（日期数字与圆点之间） */
.wc-day-task-labels {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 6rpx 2rpx 0;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  flex: 1;
  min-height: 0;
  gap: 2rpx;
  position: relative;
  z-index: 1;
}

.wc-day-task-text {
  display: block;
  font-size: 24rpx;
  color: #333333;
  line-height: 28rpx;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  padding: 1rpx 4rpx;
  border-radius: 4rpx;
  box-sizing: border-box;
  position: relative;
}

/* ===== 多天任务跨格子（周级别绝对定位层） ===== */
.wc-multi-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  pointer-events: none;
  overflow: hidden;
}

.wc-multi-bar {
  position: absolute;
  box-sizing: border-box;
  overflow: hidden;
  pointer-events: auto;
  border-radius: 4rpx;
  display: flex;
  align-items: flex-start;
}

.wc-multi-bar-text {
  display: block;
  font-size: 24rpx;
  line-height: 24rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  box-sizing: border-box;
  width: 100%;
  padding: 2rpx 4rpx;
}

/* 优先级背景色 */
.wc-day-task-p0 { background: #f0f0f0; color: #666666; }
.wc-day-task-p1 { background: #dbeafe; color: #1d4ed8; }
.wc-day-task-p2 { background: #fef3c7; color: #92400e; }
.wc-day-task-p3 { background: #fee2e2; color: #991b1b; }

.wc-day-dot-extra {
  font-size: 16rpx;
  color: #07c160;
  line-height: 20rpx;
  text-align: center;
}

/* 任务小圆点 */
.wc-day-dots {
  display: flex;
  gap: 4rpx;
  margin-top: auto;
  padding-bottom: 6rpx;
}

.wc-day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #07c160;
}

/* ===== 下一周行（面板打开时底部显示） ===== */
.wc-next-week {
  background: #ffffff;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

/* ===== 暗色模式（通过 .dark class 切换，由 ThemeManager 控制） ===== */
.wx-calendar.dark { background: #111111; }
.wx-calendar.dark .wc-header { background: #1e1e1e; }
.wx-calendar.dark .wc-nav-icon { color: #e0e0e0; }
.wx-calendar.dark .wc-year-input,
.wx-calendar.dark .wc-month-input {
  color: #e0e0e0;
  border-color: #3a3a3a;
  background: #2c2c2c;
}
.wx-calendar.dark .wc-year-input:focus,
.wx-calendar.dark .wc-month-input:focus {
  border-color: #07c160;
  background: #1e1e1e;
}
.wx-calendar.dark .wc-separator { color: #e0e0e0; }
.wx-calendar.dark .wc-nav-btn:active { background: #2c2c2c; }
.wx-calendar.dark .wc-today-btn { background: #2c2c2c; color: #e0e0e0; }
.wx-calendar.dark .wc-today-btn:active { background: #06ad56; }
.wx-calendar.dark .wc-weekdays { background: #1e1e1e; }
.wx-calendar.dark .wc-weekday { color: #666666; }
.wx-calendar.dark .wc-weekday-weekend { color: #c45c5c; }
.wx-calendar.dark .wc-scroll { background: #1e1e1e; }
.wx-calendar.dark .wc-cal-week-row { background: #1e1e1e; border-left-color: #333333; border-top-color: #333333; }
.wx-calendar.dark .wc-day { border-right-color: #333333; border-bottom-color: #333333; }
.wx-calendar.dark .wc-day:active { background: rgba(255, 255, 255, 0.03); }
.wx-calendar.dark .wc-day-month-label { color: #666666; }
.wx-calendar.dark .wc-day-num { color: #e0e0e0; }
.wx-calendar.dark .wc-day-lunar { color: #666666; }
.wx-calendar.dark .wc-day-lunar-term { color: #07c160; }
.wx-calendar.dark .wc-day-lunar-festival { color: #fa5151; }
.wx-calendar.dark .wc-day-lunar-month { color: #e0e0e0; }
.wx-calendar.dark .wc-day-other-month .wc-day-num { color: #444444; }
.wx-calendar.dark .wc-day-other-month .wc-day-dot { background: #444444; }
.wx-calendar.dark .wc-day-today .wc-day-num { background: #07c160; color: #ffffff; }
.wx-calendar.dark .wc-day-selected .wc-day-num { background: #0d2818; color: #07c160; }
.wx-calendar.dark .wc-day-today.wc-day-selected .wc-day-num { background: #07c160; color: #ffffff; }
.wx-calendar.dark .wc-day-weekend .wc-day-num { color: #c45c5c; }
.wx-calendar.dark .wc-day-today.wc-day-weekend .wc-day-num { background: #07c160; color: #ffffff; }
.wx-calendar.dark .wc-day-dot { background: #07c160; }
.wx-calendar.dark .wc-day-task-text { color: #e0e0e0; }
.wx-calendar.dark .wc-day-task-p0 { background: #2c2c2c; color: #e0e0e0; }
.wx-calendar.dark .wc-day-task-p1 { background: #1e3a5f; color: #93c5fd; }
.wx-calendar.dark .wc-day-task-p2 { background: #3d2e0a; color: #fcd34d; }
.wx-calendar.dark .wc-day-task-p3 { background: #3d1010; color: #fca5a5; }
.wx-calendar.dark .wc-day-dot-extra { color: #07c160; }
/* 固定行 / 下一周行 */
.wx-calendar.dark .wc-pinned-week { background: #1e1e1e; border-bottom-color: #333333; }
.wx-calendar.dark .wc-next-week { background: #1e1e1e; }
/* 内联任务面板 */
.wx-calendar.dark .wc-task-panel { background: #1e1e1e; border-bottom-color: #333333; }
.wx-calendar.dark .wc-sheet-header { background: #1e1e1e; }
.wx-calendar.dark .wc-sheet-date-main { color: #e0e0e0; }
.wx-calendar.dark .wc-task-count { color: #666666; }
.wx-calendar.dark .wc-add-btn-sm { background: #2c2c2c; }
.wx-calendar.dark .wc-task-item { background: #2c2c2c; }
.wx-calendar.dark .wc-task-title { color: #e0e0e0; }
.wx-calendar.dark .wc-title-done { color: #555555; }
.wx-calendar.dark .wc-task-desc { color: #666666; }
.wx-calendar.dark .wc-task-checkbox { border-color: #444444; }
.wx-calendar.dark .wc-task-item.priority-3 .wc-task-checkbox { border-color: #fa5151; }
.wx-calendar.dark .wc-task-checkbox.completed { background: #07c160; border-color: #07c160; }
.wx-calendar.dark .wc-task-checkbox.completed .wc-check-icon { color: #ffffff; }
.wx-calendar.dark .wc-completed-title { color: #666666; }
.wx-calendar.dark .wc-show-completed-text { color: #6b8ab9; }
.wx-calendar.dark .wc-empty-text { color: #e0e0e0; }
.wx-calendar.dark .wc-empty-hint { color: #666666; }
