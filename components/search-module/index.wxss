.search-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.search-icon {
  font-size: 32rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
}

.search-results {
  /* 嵌套在 scroll-view 中，不再独立滚动 */
}

.search-result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
  transition: background 0.2s;
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-item:active {
  background: rgba(0, 0, 0, 0.03);
}

.result-status {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  border: 3rpx solid #d1d5db;
  flex-shrink: 0;
  margin-right: 16rpx;
  transition: all 0.3s ease;
  background: #fff;
}

.result-status.completed {
  border-color: transparent;
  background: transparent;
}

.result-status .icon {
  display: inline-block;
  opacity: 0;
  transform: scale(0);
}

.result-status.completed .icon {
  font-size: 44rpx;
  color: #90ee90;
  opacity: 1;
  transform: scale(1);
}

/* 搜索结果优先级边框颜色 */
.search-result-item.priority-0 .result-status { border-color: #d1d5db; }
.search-result-item.priority-1 .result-status { border-color: #93c5fd; }
.search-result-item.priority-2 .result-status { border-color: #fcd34d; }
.search-result-item.priority-3 .result-status { border-color: #fca5a5; }

/* 搜索结果完成状态优先级勾选颜色 */
.search-result-item.priority-0 .result-status.completed .icon { color: #b0b0b0; }
.search-result-item.priority-1 .result-status.completed .icon { color: #60a5fa; }
.search-result-item.priority-2 .result-status.completed .icon { color: #fbbf24; }
.search-result-item.priority-3 .result-status.completed .icon { color: #f87171; }

.result-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.result-title {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-date {
  font-size: 24rpx;
  color: #999;
}

.search-empty {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
